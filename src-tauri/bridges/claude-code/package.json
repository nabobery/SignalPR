{
  "name": "claude-code-bridge",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "pkg": "node scripts/build-sidecar.mjs",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.1.75"
  },
  "devDependencies": {
    "@types/node": "^24.9.1",
    "@yao-pkg/pkg": "^6.0.0",
    "typescript": "~5.8.3"
  },
  "pkg": {
    "targets": ["node20"],
    "outputPath": "../../binaries",
    "assets": [
      "node_modules/@anthropic-ai/claude-agent-sdk/**/*"
    ]
  }
}
