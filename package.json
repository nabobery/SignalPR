{
  "name": "signalpr",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.23.0",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "lint": "pnpm exec oxlint src/",
    "lint:fix": "pnpm exec oxlint --fix src/",
    "lint:rust": "cargo clippy --manifest-path src-tauri/Cargo.toml -- -D warnings",
    "format": "pnpm exec oxfmt 'src/**/*.{ts,tsx,css}'",
    "format:check": "pnpm exec oxfmt --check 'src/**/*.{ts,tsx,css}'",
    "format:rust": "cargo fmt --manifest-path src-tauri/Cargo.toml",
    "format:rust:check": "cargo fmt --manifest-path src-tauri/Cargo.toml -- --check",
    "typecheck": "tsc --noEmit",
    "test:rust": "cargo test --manifest-path src-tauri/Cargo.toml",
    "test:frontend": "vitest run",
    "test": "pnpm test:rust && pnpm test:frontend",
    "check:bridge": "pnpm --dir src-tauri/bridges/claude-code typecheck && pnpm --dir src-tauri/bridges/claude-code build && pnpm --dir src-tauri/bridges/claude-code run pkg",
    "check:frontend": "pnpm typecheck && pnpm lint && pnpm format:check",
    "check:rust": "pnpm lint:rust && pnpm format:rust:check && pnpm test:rust",
    "check": "pnpm check:frontend && pnpm check:bridge && pnpm check:rust",
    "sidecar:claude-code:build": "(test -d src-tauri/bridges/claude-code/node_modules || (CI=true pnpm --dir src-tauri/bridges/claude-code --ignore-workspace install --offline --frozen-lockfile || CI=true pnpm --dir src-tauri/bridges/claude-code --ignore-workspace install --frozen-lockfile)) && pnpm check:bridge",
    "eval:validate": "node evals/validate.mjs",
    "eval:run": "node evals/run-paid.mjs"
  },
  "dependencies": {
    "@pierre/diffs": "1.2.12",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "lucide-react": "^1.24.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-error-boundary": "^6.1.2",
    "react-router": "^7.13.2"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@tauri-apps/cli": "^2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "jsdom": "^29.1.1",
    "oxfmt": "0.58.0",
    "oxlint": "1.73.0",
    "tailwindcss": "^4.3.2",
    "typescript": "~5.8.3",
    "vite": "^7.0.4",
    "vitest": "^4.1.10"
  }
}
